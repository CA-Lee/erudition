{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Server",
      "type": "shell",
      "command": "pnpm dev",
      "options": {
        "cwd": "${workspaceFolder}/packages/server"
      },
      "presentation": {
        "panel": "dedicated",
        "group": "dev"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Start Client",
      "type": "shell",
      "command": "pnpm dev",
      "options": {
        "cwd": "${workspaceFolder}/packages/client"
      },
      "presentation": {
        "panel": "dedicated",
        "group": "dev"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Start Tunnel",
      "type": "shell",
      "command": "bash -c 'set -a; source ${workspaceFolder}/.env.local; set +a; cloudflared tunnel run --token $CLOUDFLARED_TOKEN'",
      "presentation": {
        "panel": "dedicated",
        "group": "dev"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Dev Suite",
      "dependsOn": ["Start Server", "Start Client", "Start Tunnel"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
