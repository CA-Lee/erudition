{
  "name": "erudition",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vue-tsc --build && vite build",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "deploy": "pnpm wrangler auth token >/dev/null || wrangler login --callback-host=127.0.0.1 && wrangler deploy",
    "cf-typegen": "wrangler types",
    "lint": "eslint ."
  },
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=10"
  },
  "dependencies": {
    "hono": "^4.12.8",
    "jose": "^6.2.1",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.28.0",
    "@cloudflare/workers-types": "^4.20260313.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.1.0",
    "vue-tsc": "^3.2.5",
    "wrangler": "^4.73.0"
  }
}